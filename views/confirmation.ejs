<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <title>Booking Confirmed</title>
</head>
<body style="text-align: center;">
    
<div class="main-container" style="background: white; padding: 30px; border-radius: 15px; text-align: center; max-width: 450px; margin: auto;">
    
    <div style="font-size: 50px; color: #28a745;">✔</div>
    <h2 style="color: #081A39;">Booking Successful!</h2>
    
    <p>Your Darshan at <strong><%= temple %></strong> is confirmed.</p>
    <p><strong>Date:</strong> <%= date %></p>
    <p><strong>Slot:</strong> <%= slot %></p>
    <hr style="border: 0.5px solid #eee; margin: 20px 0;">

    <div style="display: flex; flex-direction: column; gap: 15px; align-items: center;">
        
        <a href="/" style="background: #081A39; color: #FFD700; padding: 12px; width: 100%; text-decoration: none; border-radius: 5px; font-weight: bold; box-sizing: border-box;">
            Back to Home
        </a>

        <form action="/download-receipt" method="POST" style="width: 100%;">
            <input type="hidden" name="temple" value="<%= temple %>">
            <input type="hidden" name="date" value="<%= date %>">
            <input type="hidden" name="slot" value="<%= slot %>">
            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 12px; width: 100%; border-radius: 5px; font-weight: bold; cursor: pointer;">
                PDF - Download Receipt 📥
            </button>
        </form>

        <a href="/history/<%= email %>" style="color: #081A39; font-weight: bold; text-decoration: none; font-size: 0.9rem;">
            📜 View My Booking History
        </a>

    
    <a href="/" style="color: #081A39; text-decoration: underline; font-size: 0.9rem; margin-top: 10px;">
        Back to Home
    </a>
</div>
</body>
</html>